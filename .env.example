NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:5180
AUTH_MODE=okta

# Okta OIDC
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_SCOPES=openid profile email

# Temporary Google IAP mode
IAP_EXPECTED_AUDIENCE=
IAP_ALLOWED_DOMAIN=flyr.com
GOOGLE_CLOUD_PROJECT_NUMBER=

# Session and bootstrap access
SESSION_SECRET=replace-me
SESSION_COOKIE_NAME=loadfactor_session
AUTH_STATE_COOKIE_NAME=loadfactor_auth_state
SESSION_MAX_AGE_SECONDS=43200
AUTH_STATE_MAX_AGE_SECONDS=600
BOOTSTRAP_ADMIN_EMAILS=alex@example.com

# Local development bypass. Set this to false when you want to test real Okta locally.
DEV_AUTH_BYPASS=true
DEV_AUTH_BYPASS_EMAIL=alex@example.com
DEV_AUTH_BYPASS_NAME=Alex Local

# Optional Cloud Run metadata
K_SERVICE=loadfactor
GOOGLE_CLOUD_PROJECT=
